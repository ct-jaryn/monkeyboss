# MonkeyBoss 配置文件
# 复制此文件为 .env 并填写实际值

# MonkeyCode 账号配置
MONKEYCODE_URL=https://monkeycode.ai
MONKEYCODE_USERNAME=
MONKEYCODE_PASSWORD=

# AI 服务配置
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o
AI_BASE_URL=

# 浏览器配置
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000

# 任务配置
TASK_PROJECT_NAME=
TASK_DESCRIPTION=
TASK_MAX_ITERATIONS=1000
TASK_LOOP_INTERVAL=5000

# 日志配置
LOG_LEVEL=info
LOG_FILE=monkeyboss.log
